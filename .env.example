# ====================================================================================
# ClassMate Backend - Environment Template (.env.example)
# Copy to .env and fill values:
#   cp .env.example .env
# - JWT_SECRET must be >= 32 chars (recommended 64+)
# ====================================================================================

# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_DB=classmate
POSTGRES_USER=classmate
POSTGRES_PASSWORD=classmate123

# -----------------------------
# JWT Secret (User Service + Gateway)
# -----------------------------
JWT_SECRET=REPLACE_WITH_64PLUS_CHAR_SECRET

# -----------------------------
# Spring Profile
# -----------------------------
SPRING_PROFILES_ACTIVE=docker
